{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://two-weeks-team.github.io/PreviewForgeForClaudeCode/schemas/pf-profile.schema.json",
  "title": "PF Profile",
  "description": "Preview Forge run profile — controls cost, speed, and thoroughness of a 3-DD cycle. Three values ship: standard (cheapest), pro (default, balanced), max (all-in 143 agents).",
  "type": "object",
  "required": [
    "name",
    "version",
    "previews",
    "engineering",
    "qa",
    "panels",
    "scc",
    "budget",
    "caching",
    "cost_ceiling"
  ],
  "properties": {
    "name": {
      "type": "string",
      "enum": ["standard", "pro", "max"],
      "description": "Profile identifier used by --profile flag and settings.json defaultProfile."
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "previews": {
      "type": "object",
      "required": ["count", "max_user_expand"],
      "properties": {
        "count": {
          "type": "integer",
          "minimum": 3,
          "maximum": 26,
          "description": "Number of Preview Advocates to dispatch in PreviewDD."
        },
        "max_user_expand": {
          "type": "integer",
          "minimum": 3,
          "maximum": 26,
          "description": "Upper bound if user requests --previews=N override."
        }
      }
    },
    "engineering": {
      "type": "object",
      "required": ["teams", "members_per_team", "disciplines"],
      "properties": {
        "teams": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "members_per_team": {
          "type": "integer",
          "minimum": 3,
          "maximum": 5
        },
        "disciplines": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["backend", "frontend", "database", "devops", "sdk"]
          },
          "minItems": 2,
          "uniqueItems": true
        }
      }
    },
    "qa": {
      "type": "object",
      "required": ["security", "performance", "accessibility", "functional", "tools_retained"],
      "properties": {
        "security": { "type": "integer", "minimum": 1, "maximum": 5 },
        "performance": { "type": "integer", "minimum": 1, "maximum": 5 },
        "accessibility": { "type": "integer", "minimum": 1, "maximum": 5 },
        "functional": { "type": "integer", "minimum": 1, "maximum": 5 },
        "tools_retained": {
          "type": "array",
          "description": "Tools always run regardless of agent count. Load-bearing per quality-engineer panel vote.",
          "items": {
            "type": "string",
            "enum": ["semgrep", "gitleaks", "axe-core", "lighthouse", "owasp-zap"]
          }
        }
      }
    },
    "panels": {
      "type": "object",
      "required": ["mode", "keyword_triggers", "escalation"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["off", "keyword-trigger", "always"],
          "description": "off: skip all 4 panels. keyword-trigger: only activate panels whose keywords match. always: run all 4."
        },
        "keyword_triggers": {
          "type": "object",
          "properties": {
            "tp": { "type": "array", "items": { "type": "string" } },
            "bp": { "type": "array", "items": { "type": "string" } },
            "up": { "type": "array", "items": { "type": "string" } },
            "rp": { "type": "array", "items": { "type": "string" } }
          }
        },
        "escalation": {
          "type": "object",
          "required": ["on_unknown_unknown", "confidence_threshold"],
          "properties": {
            "on_unknown_unknown": {
              "type": "boolean",
              "description": "If advocate vote dispersion > threshold, auto-escalate to full panel."
            },
            "confidence_threshold": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0
            }
          }
        }
      }
    },
    "scc": {
      "type": "object",
      "required": ["max_iter", "auto_extend_on_error_decrease"],
      "properties": {
        "max_iter": { "type": "integer", "minimum": 1, "maximum": 10 },
        "auto_extend_on_error_decrease": {
          "type": "boolean",
          "description": "Extend by +1 iter when error count trajectory is decreasing."
        }
      }
    },
    "budget": {
      "type": "object",
      "required": ["advocate_tokens", "panel_tokens", "eng_tokens", "spec_tokens"],
      "properties": {
        "advocate_tokens": { "type": "integer", "minimum": 500 },
        "panel_tokens": { "type": "integer", "minimum": 200 },
        "eng_tokens": { "type": "integer", "minimum": 2000 },
        "spec_tokens": { "type": "integer", "minimum": 1500 }
      }
    },
    "caching": {
      "type": "object",
      "required": ["preview_dd", "ttl_seconds"],
      "properties": {
        "preview_dd": { "type": "boolean" },
        "ttl_seconds": { "type": "integer", "minimum": 0 }
      }
    },
    "cost_ceiling": {
      "type": "object",
      "required": ["p95_tokens", "p95_minutes", "hard_tokens", "hard_minutes"],
      "description": "Telemetry baselines used by monitors/cost-regression.sh. Breach triggers AskUserQuestion pause.",
      "properties": {
        "p95_tokens": { "type": "integer", "minimum": 1000 },
        "p95_minutes": { "type": "integer", "minimum": 1 },
        "hard_tokens": { "type": "integer", "minimum": 1000 },
        "hard_minutes": { "type": "integer", "minimum": 1 }
      }
    },
    "stack": {
      "type": "object",
      "description": "v1.4+ — stack hints consumed by Engineering scaffold. Tells SpecDD/Engineering lead which DB engine + containerize flag to use. Frontend/backend split already comes from detect-surface.sh.",
      "required": ["db", "containerize", "migration_cmd"],
      "properties": {
        "db": {
          "type": "string",
          "enum": ["sqlite", "sqlite-or-postgres", "postgres"]
        },
        "db_file_location": { "type": "string" },
        "containerize": { "type": "boolean" },
        "migration_cmd": { "type": "string" }
      }
    },
    "profile_escalation": {
      "type": "object",
      "description": "v1.4+ — pre-flight profile recommender config. If current profile detects enterprise signals, suggest upgrade. HARD_REQUIRE signals force upgrade; SOFT_SUGGEST signals ask via AskUserQuestion.",
      "required": ["upgrade_to", "confidence_threshold", "min_distinct_categories", "hard_require_signals", "soft_suggest_categories"],
      "properties": {
        "upgrade_to": {
          "type": "string",
          "enum": ["standard", "pro", "max"]
        },
        "confidence_threshold": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "hard_require_signals": {
          "type": "array",
          "description": "Categories that FORCE upgrade, no user dismiss. E.g., PII/Stripe/HIPAA.",
          "items": {
            "type": "string",
            "enum": ["payments", "phi_healthcare", "pii_storage", "auth_provider"]
          }
        },
        "soft_suggest_categories": {
          "type": "array",
          "description": "Categories that trigger AskUserQuestion. User may decline.",
          "items": {
            "type": "string",
            "enum": ["compliance", "multi_tenant", "enterprise_b2b", "scale"]
          }
        },
        "min_distinct_categories": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4,
          "description": "Devops-architect CP-2: require ≥N distinct signal categories (not just keyword count) to fire."
        }
      }
    }
  }
}
