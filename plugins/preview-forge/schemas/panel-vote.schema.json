{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/Two-Weeks-Team/PreviewForgeForClaudeCode/schemas/panel-vote.schema.json",
  "title": "PanelVote",
  "description": "A single panel member's vote in PreviewDD Stage 3b (runoff).",
  "type": "object",
  "required": [
    "panel",
    "member_id",
    "vote",
    "confidence",
    "rationale",
    "primary_concern"
  ],
  "properties": {
    "panel": {
      "type": "string",
      "enum": [
        "TP",
        "BP",
        "UP",
        "RP"
      ]
    },
    "member_id": {
      "type": "string",
      "pattern": "^(TP|BP|UP|RP)[0-9]{2}$"
    },
    "vote": {
      "type": "string",
      "pattern": "^P[0-9]{2}$|^OTHER$|^ABSTAIN$"
    },
    "confidence": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "rationale": {
      "type": "string",
      "minLength": 10
    },
    "primary_concern": {
      "type": "string"
    },
    "dissenting_note": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": false
}