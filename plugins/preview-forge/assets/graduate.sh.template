#!/usr/bin/env bash
# Preview Forge — graduate.sh (additive profile elevation)
#
# Generated by standard profile scaffold. Call from project root:
#   bash scripts/graduate.sh pro    # adds Docker + Postgres datasource
#   bash scripts/graduate.sh max    # adds CI/CD + observability
#
# devops-architect CP-1: additive. Existing package.json, app code, schema
# models are preserved. Only container/CI artifacts are written.

set -euo pipefail

TARGET="${1:-}"
case "$TARGET" in
  pro|max) ;;
  *)
    echo "usage: graduate.sh {pro|max}" >&2
    exit 64
    ;;
esac

echo "→ graduating to $TARGET profile (additive, preserves existing code)"

# 1. Prisma datasource swap
if [[ -f prisma/schema.prisma ]]; then
  # Portability lint first. If schema uses SQLite-only features, abort.
  if command -v python3 >/dev/null && [[ -f scripts/standard-schema-lint.py ]]; then
    python3 scripts/standard-schema-lint.py prisma/schema.prisma || {
      echo "✗ schema has non-portable features. Fix above violations, rerun graduate." >&2
      exit 2
    }
  fi

  # Replace datasource provider + url (use env DATABASE_URL — same env var,
  # different contents: file:dev.db → postgres://...)
  # Use POSIX [[:space:]] — GNU \s is not portable to BSD sed (macOS default).
  sed -i.bak -E 's|provider[[:space:]]*=[[:space:]]*"sqlite"|provider = "postgresql"|' prisma/schema.prisma
  rm -f prisma/schema.prisma.bak
  echo "  ✓ prisma/schema.prisma: sqlite → postgresql"

  # Convert db push state to migrate history (Prisma migrate resolve)
  if [[ -d prisma/migrations ]]; then
    echo "  ○ prisma/migrations/ already exists — skipping migrate init"
  else
    echo "  → run manually: npx prisma migrate dev --name init_from_standard"
  fi
fi

# 2. Dockerfile + compose (only if not present)
if [[ ! -f Dockerfile ]]; then
  cat > Dockerfile <<'DOCKERFILE'
# Preview Forge — generated on graduate to pro/max
FROM node:22-alpine AS deps
WORKDIR /app
COPY package*.json ./
RUN npm ci --omit=dev

FROM node:22-alpine AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .
RUN npm run build

FROM node:22-alpine
WORKDIR /app
ENV NODE_ENV=production
COPY --from=builder /app/.next ./.next
COPY --from=builder /app/public ./public
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/package.json ./
EXPOSE 3000
CMD ["npm","run","start"]
DOCKERFILE
  echo "  ✓ Dockerfile"
fi

if [[ ! -f docker-compose.yml ]]; then
  cat > docker-compose.yml <<'COMPOSE'
# Credentials come from .env (not committed). Copy .env.example → .env and fill.
services:
  app:
    build: .
    ports: ["3000:3000"]
    env_file: [.env]
    depends_on: [db]
  db:
    image: postgres:16-alpine
    env_file: [.env]
    ports: ["5432:5432"]
    volumes: ["pg_data:/var/lib/postgresql/data"]

volumes:
  pg_data:
COMPOSE
  cat > .env.example <<'ENVEX'
# Copy to .env before `docker compose up`. .env is gitignored.
POSTGRES_USER=pf
POSTGRES_PASSWORD=change-me-before-deploy
POSTGRES_DB=pf
DATABASE_URL=postgres://pf:change-me-before-deploy@db:5432/pf
ENVEX
  echo "  ✓ docker-compose.yml + .env.example (credentials via env_file)"
fi

if [[ ! -f .dockerignore ]]; then
  cat > .dockerignore <<'DOCKERIGNORE'
node_modules
.next
*.db
*.db-wal
*.db-shm
.env
.env.*
!.env.example
DOCKERIGNORE
  echo "  ✓ .dockerignore"
fi

# 3. max-only: CI/CD + observability stubs
if [[ "$TARGET" == "max" ]]; then
  mkdir -p .github/workflows
  if [[ ! -f .github/workflows/deploy.yml ]]; then
    cat > .github/workflows/deploy.yml <<'CI'
name: Deploy
on:
  push:
    branches: [main]
jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v6
      - uses: actions/setup-node@v6
        with: { node-version: '22' }
      - run: npm ci
      - run: npm run build
      - run: docker build -t $IMAGE .
        env:
          IMAGE: ${{ github.repository }}/app:${{ github.sha }}
      # TODO: push to registry + deploy to managed platform
CI
    echo "  ✓ .github/workflows/deploy.yml (max)"
  fi
fi

echo ""
echo "✓ graduated to $TARGET."
echo "  Next: review Dockerfile + docker-compose.yml + prisma/schema.prisma,"
echo "  then: docker compose up --build"
