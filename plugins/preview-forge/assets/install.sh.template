#!/usr/bin/env bash
# Preview Forge — initial install.sh template (run ONCE on target server)
# This script is generated by Preview Forge DevOps Team.
# Gate H2 must be approved before deploying.

set -euo pipefail

PROJECT="${1:-preview-forge-app}"
DEPLOY_DIR="/opt/${PROJECT}"

echo "[install] creating ${DEPLOY_DIR}"
sudo mkdir -p "${DEPLOY_DIR}"
sudo chown "$USER" "${DEPLOY_DIR}"

echo "[install] preparing .env (edit manually before compose up)"
if [[ ! -f "${DEPLOY_DIR}/.env" ]]; then
  cat > "${DEPLOY_DIR}/.env" <<ENV
PROJECT=${PROJECT}
POSTGRES_USER=app
POSTGRES_PASSWORD=$(openssl rand -hex 16)
POSTGRES_DB=app
DATABASE_URL=postgresql://app:\${POSTGRES_PASSWORD}@db:5432/app
ENV
  echo "[install] .env created. Review and edit if needed."
else
  echo "[install] .env already exists, skipping."
fi

echo "[install] bringing up stack"
cd "${DEPLOY_DIR}"
docker compose -f docker-compose.yml up -d

echo "[install] waiting for health..."
for i in {1..30}; do
  if curl -fs http://localhost:18080/health >/dev/null; then
    echo "[install] healthy on :18080"
    break
  fi
  sleep 2
done

echo "[install] done. Logs: docker compose logs -f"
