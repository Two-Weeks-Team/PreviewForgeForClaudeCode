{
  "env": {
    "PF_EFFORT_DEFAULT": "high",
    "PF_BATCH_API_ENABLED": "true",
    "PF_CACHE_TTL": "1h",
    "PF_MANAGED_AGENTS": "true",
    "PF_DEFAULT_PROFILE": "pro",
    "PF_CONTEXT_EDITING": "context-management-2025-06-27",
    "PF_COMPACT_BETA": "compact_20260112",
    "PF_TASK_BUDGETS_BETA": "task-budgets-2026-03-13"
  },
  "pf": {
    "defaultProfile": "pro",
    "profiles": {
      "standard": "./profiles/standard.json",
      "pro": "./profiles/pro.json",
      "max": "./profiles/max.json"
    },
    "driftDetection": {
      "enabled": true,
      "minSimilarity": 0.7,
      "onBreach": "block-and-ask"
    },
    "costRegression": {
      "enabled": true,
      "onSoftBreach": "warn",
      "onHardBreach": "pause-and-ask"
    }
  }
}
